#usda 1.0
(
    defaultPrim = "Asset"
    upAxis = "Y"
)

def Xform "Asset"
{
    def Cube "Shape" (
        prepend apiSchemas = ["MaterialBindingAPI"]
    )
    {
        double size = 1
        rel material:binding = </Asset/Looks/Green>
    }

    def Scope "Looks"
    {
        def Material "Green"
        {
            token outputs:surface.connect = </Asset/Looks/Green/Preview.outputs:surface>

            def Shader "Preview"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0.1, 0.65, 0.22)
                float inputs:roughness = 0.45
                token outputs:surface
            }
        }
    }
}
