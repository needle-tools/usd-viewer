#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1
    upAxis = "Z"
)

def Xform "World"
{
    def Mesh "CustomNodeDefPanel" (
        prepend apiSchemas = ["MaterialBindingAPI"]
    )
    {
        rel material:binding = </Looks/MaterialX/Materials/Custom_NodeDef_Surface>
        uniform token subdivisionScheme = "none"
        int[] faceVertexCounts = [4]
        int[] faceVertexIndices = [0, 1, 2, 3]
        point3f[] points = [(-1.0, 0, -1.0), (1.0, 0, -1.0), (1.0, 0, 1.0), (-1.0, 0, 1.0)]
        normal3f[] primvars:normals = [(0, -1, 0)] (
            interpolation = "constant"
        )
        vector3f[] primvars:tangents = [(1, 0, 0)] (
            interpolation = "constant"
        )
        texCoord2f[] primvars:st = [(0, 0), (1, 0), (1, 1), (0, 1)] (
            interpolation = "vertex"
        )
        color3f[] primvars:displayColor = [(0.7, 0.2, 1.0)] (
            interpolation = "constant"
        )
    }

    def DistantLight "Key"
    {
        float inputs:intensity = 380
        float inputs:angle = 0.35
        float3 xformOp:rotateXYZ = (-40, 0, 35)
        uniform token[] xformOpOrder = ["xformOp:rotateXYZ"]
    }

    def Camera "Camera"
    {
        float focalLength = 35
        float horizontalAperture = 21
        matrix4d xformOp:transform = ( (1, 0, 0, 0), (0, 0.35, 0.94, 0), (0, -0.94, 0.35, 0), (0, -3.6, 1.8, 1) )
        uniform token[] xformOpOrder = ["xformOp:transform"]
    }
}

def Scope "Looks"
{
    def "MaterialX" (
        references = [
            @./mtlxFiles/custom_nodedef_surface.mtlx@</MaterialX>
        ]
    )
    {
    }
}
