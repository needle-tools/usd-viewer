#usda 1.0
(
    defaultPrim = "World"
    upAxis = "Z"
)

def Xform "World"
{
    def Mesh "LoopQuadFallback" (
        prepend apiSchemas = ["MaterialBindingAPI"]
    )
    {
        rel material:binding = </Looks/QuadFallback>
        uniform token subdivisionScheme = "loop"
        int[] faceVertexCounts = [4, 3, 3, 3, 3]
        int[] faceVertexIndices = [
            0, 1, 2, 3,
            0, 4, 1,
            1, 4, 2,
            2, 4, 3,
            3, 4, 0
        ]
        point3f[] points = [
            (-2.4, -0.8, 0),
            (-0.8, -0.8, 0),
            (-0.8, 0.8, 0),
            (-2.4, 0.8, 0),
            (-1.6, 0, 1.4)
        ]
        color3f[] primvars:displayColor = [(0.95, 0.28, 0.16)]
    }

    def Mesh "LoopTrianglesRefined" (
        prepend apiSchemas = ["MaterialBindingAPI"]
    )
    {
        rel material:binding = </Looks/TriangleRefined>
        uniform token subdivisionScheme = "loop"
        int[] faceVertexCounts = [3, 3, 3, 3, 3, 3, 3, 3]
        int[] faceVertexIndices = [
            0, 2, 3,
            0, 3, 4,
            0, 4, 5,
            0, 5, 2,
            1, 3, 2,
            1, 4, 3,
            1, 5, 4,
            1, 2, 5
        ]
        point3f[] points = [
            (1.4, 0, 1.3),
            (1.4, 0, -0.3),
            (0.4, -0.9, 0.5),
            (2.4, -0.9, 0.5),
            (2.4, 0.9, 0.5),
            (0.4, 0.9, 0.5)
        ]
        color3f[] primvars:displayColor = [(0.12, 0.72, 0.42)]
    }
}

def Scope "Looks"
{
    def Material "QuadFallback"
    {
        token outputs:surface.connect = </Looks/QuadFallback/Preview.outputs:surface>

        def Shader "Preview"
        {
            uniform token info:id = "UsdPreviewSurface"
            color3f inputs:diffuseColor = (0.95, 0.28, 0.16)
            float inputs:roughness = 0.55
            token outputs:surface
        }
    }

    def Material "TriangleRefined"
    {
        token outputs:surface.connect = </Looks/TriangleRefined/Preview.outputs:surface>

        def Shader "Preview"
        {
            uniform token info:id = "UsdPreviewSurface"
            color3f inputs:diffuseColor = (0.12, 0.72, 0.42)
            float inputs:roughness = 0.38
            token outputs:surface
        }
    }
}
