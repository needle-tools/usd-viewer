#usda 1.0
(
    upAxis = "Z"
)

def Xform "World" (
    variants = {
        string shape = "sphere"
    }
    prepend variantSets = "shape"
)
{
    variantSet "shape" = {
        "cube" {
            def Cube "Shape" (
                prepend apiSchemas = ["MaterialBindingAPI"]
                variants = {
                    string finish = "warm"
                }
                prepend variantSets = "finish"
            )
            {
                rel material:binding = </Looks/Warm>
                double size = 1.25

                variantSet "finish" = {
                    "cool" {
                        over "Shape"
                        {
                            rel material:binding = </Looks/Cool>
                        }
                    }
                    "warm" {
                        over "Shape"
                        {
                            rel material:binding = </Looks/Warm>
                        }
                    }
                }
            }
        }
        "sphere" {
            def Sphere "Shape" (
                prepend apiSchemas = ["MaterialBindingAPI"]
                variants = {
                    string finish = "cool"
                }
                prepend variantSets = "finish"
            )
            {
                rel material:binding = </Looks/Cool>
                double radius = 0.85

                variantSet "finish" = {
                    "cool" {
                        over "Shape"
                        {
                            rel material:binding = </Looks/Cool>
                        }
                    }
                    "warm" {
                        over "Shape"
                        {
                            rel material:binding = </Looks/Warm>
                        }
                    }
                }
            }
        }
    }
}

def Scope "Looks"
{
    def Material "Warm"
    {
        token outputs:surface.connect = </Looks/Warm/Preview.outputs:surface>

        def Shader "Preview"
        {
            uniform token info:id = "UsdPreviewSurface"
            color3f inputs:diffuseColor = (1, 0.45, 0.1)
            float inputs:roughness = 0.35
            token outputs:surface
        }
    }

    def Material "Cool"
    {
        token outputs:surface.connect = </Looks/Cool/Preview.outputs:surface>

        def Shader "Preview"
        {
            uniform token info:id = "UsdPreviewSurface"
            color3f inputs:diffuseColor = (0.05, 0.45, 1)
            float inputs:roughness = 0.2
            token outputs:surface
        }
    }
}
