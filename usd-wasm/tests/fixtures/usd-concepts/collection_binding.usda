#usda 1.0
(
    upAxis = "Z"
)

def Xform "World" (
    prepend apiSchemas = ["CollectionAPI:material:painted", "MaterialBindingAPI"]
)
{
    rel collection:material:painted:includes = [
        </World/Left>,
        </World/Right>,
    ]
    uniform token collection:material:painted:expansionRule = "expandPrims"
    rel material:binding:collection:painted = [
        </World.collection:material:painted>,
        </Looks/CollectionGold>,
    ]

    def Cube "Left"
    {
        double size = 0.55
        double3 xformOp:translate = (-0.45, 0, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    def Sphere "Right"
    {
        double radius = 0.32
        double3 xformOp:translate = (0.45, 0, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }
}

def Scope "Looks"
{
    def Material "CollectionGold"
    {
        token outputs:surface.connect = </Looks/CollectionGold/Preview.outputs:surface>

        def Shader "Preview"
        {
            uniform token info:id = "UsdPreviewSurface"
            color3f inputs:diffuseColor = (1, 0.78, 0.1)
            float inputs:metallic = 0.65
            float inputs:roughness = 0.22
            token outputs:surface
        }
    }
}
