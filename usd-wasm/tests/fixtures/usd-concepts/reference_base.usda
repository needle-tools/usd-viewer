#usda 1.0
(
    defaultPrim = "Model"
    upAxis = "Z"
)

def Xform "Model"
{
    def Cube "Shape" (
        prepend apiSchemas = ["MaterialBindingAPI"]
    )
    {
        double size = 0.9
        rel material:binding = </Model/Looks/BaseRed>
    }

    def Scope "Looks"
    {
        def Material "BaseRed"
        {
            token outputs:surface.connect = </Model/Looks/BaseRed/Preview.outputs:surface>

            def Shader "Preview"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0.95, 0.1, 0.08)
                float inputs:roughness = 0.5
                token outputs:surface
            }
        }
    }
}
