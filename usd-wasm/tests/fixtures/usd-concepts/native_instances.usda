#usda 1.0
(
    upAxis = "Z"
)

def Scope "Looks"
{
    def Material "InstanceGreen"
    {
        token outputs:surface.connect = </Looks/InstanceGreen/Preview.outputs:surface>

        def Shader "Preview"
        {
            uniform token info:id = "UsdPreviewSurface"
            color3f inputs:diffuseColor = (0.05, 0.75, 0.25)
            float inputs:roughness = 0.45
            token outputs:surface
        }
    }
}

class Xform "Prototype"
{
    def Cube "Shape" (
        prepend apiSchemas = ["MaterialBindingAPI"]
    )
    {
        double size = 0.7
        rel material:binding = </Looks/InstanceGreen>
    }
}

def Xform "World"
{
    def Xform "InstanceA" (
        instanceable = true
        prepend references = </Prototype>
    )
    {
        double3 xformOp:translate = (-0.65, 0, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    def Xform "InstanceB" (
        instanceable = true
        prepend references = </Prototype>
    )
    {
        double3 xformOp:translate = (0.65, 0, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }
}
