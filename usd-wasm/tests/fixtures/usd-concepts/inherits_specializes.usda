#usda 1.0
(
    upAxis = "Z"
)

class Xform "ClassCube"
{
    def Cube "Shape" (
        prepend apiSchemas = ["MaterialBindingAPI"]
    )
    {
        double size = 0.55
        rel material:binding = </Looks/ClassWarm>
    }
}

class Xform "SpecializedSphere"
{
    def Sphere "Shape" (
        prepend apiSchemas = ["MaterialBindingAPI"]
    )
    {
        double radius = 0.35
        rel material:binding = </Looks/SpecialCool>
    }
}

def Xform "World"
{
    def Xform "InheritedCube" (
        prepend inherits = </ClassCube>
    )
    {
        double3 xformOp:translate = (-0.55, 0, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    def Xform "SpecializedBall" (
        prepend specializes = </SpecializedSphere>
    )
    {
        double3 xformOp:translate = (0.55, 0, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }
}

def Scope "Looks"
{
    def Material "ClassWarm"
    {
        token outputs:surface.connect = </Looks/ClassWarm/Preview.outputs:surface>

        def Shader "Preview"
        {
            uniform token info:id = "UsdPreviewSurface"
            color3f inputs:diffuseColor = (1, 0.52, 0.12)
            float inputs:roughness = 0.42
            token outputs:surface
        }
    }

    def Material "SpecialCool"
    {
        token outputs:surface.connect = </Looks/SpecialCool/Preview.outputs:surface>

        def Shader "Preview"
        {
            uniform token info:id = "UsdPreviewSurface"
            color3f inputs:diffuseColor = (0.1, 0.55, 0.95)
            float inputs:roughness = 0.26
            token outputs:surface
        }
    }
}
