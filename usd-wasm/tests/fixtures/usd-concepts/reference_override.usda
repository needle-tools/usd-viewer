#usda 1.0
(
    upAxis = "Z"
)

def Xform "World"
{
    def Xform "Referenced" (
        prepend references = @./reference_base.usda@</Model>
    )
    {
        over "Shape"
        {
            double size = 1.25
            rel material:binding = </Looks/OverrideBlue>
        }
    }
}

def Scope "Looks"
{
    def Material "OverrideBlue"
    {
        token outputs:surface.connect = </Looks/OverrideBlue/Preview.outputs:surface>

        def Shader "Preview"
        {
            uniform token info:id = "UsdPreviewSurface"
            color3f inputs:diffuseColor = (0.05, 0.28, 1)
            float inputs:roughness = 0.3
            token outputs:surface
        }
    }
}
