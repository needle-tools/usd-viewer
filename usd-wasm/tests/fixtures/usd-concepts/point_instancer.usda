#usda 1.0
(
    upAxis = "Z"
)

def Scope "Looks"
{
    def Material "InstancedPaint"
    {
        token outputs:surface.connect = </Looks/InstancedPaint/Preview.outputs:surface>

        def Shader "Preview"
        {
            uniform token info:id = "UsdPreviewSurface"
            color3f inputs:diffuseColor = (0.9, 0.32, 0.08)
            float inputs:roughness = 0.4
            token outputs:surface
        }
    }
}

def Xform "World"
{
    def Scope "Prototypes"
    {
        def Cube "CubeProto" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            double size = 0.45
            rel material:binding = </Looks/InstancedPaint>
        }

        def Sphere "SphereProto" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            double radius = 0.28
            rel material:binding = </Looks/InstancedPaint>
        }
    }

    def PointInstancer "Scatter"
    {
        rel prototypes = [
            </World/Prototypes/CubeProto>,
            </World/Prototypes/SphereProto>,
        ]
        int[] protoIndices = [0, 1, 0]
        point3f[] positions = [(-0.7, 0, 0), (0, 0, 0), (0.7, 0, 0)]
        quath[] orientations = [(1, 0, 0, 0), (1, 0, 0, 0), (1, 0, 0, 0)]
        float3[] scales = [(1, 1, 1), (1, 1, 1), (1, 1, 1)]
    }
}
