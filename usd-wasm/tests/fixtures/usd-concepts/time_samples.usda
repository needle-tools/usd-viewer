#usda 1.0
(
    startTimeCode = 1
    endTimeCode = 48
    timeCodesPerSecond = 24
    upAxis = "Z"
)

def Xform "World"
{
    def Cube "AnimatedCube" (
        prepend apiSchemas = ["MaterialBindingAPI"]
    )
    {
        double size = 0.65
        double3 xformOp:translate.timeSamples = {
            1: (-0.8, 0, 0),
            24: (0.8, 0, 0),
            48: (-0.8, 0, 0),
        }
        uniform token[] xformOpOrder = ["xformOp:translate"]
        rel material:binding = </Looks/AnimatedMat>
    }
}

def Scope "Looks"
{
    def Material "AnimatedMat"
    {
        token outputs:surface.connect = </Looks/AnimatedMat/Preview.outputs:surface>

        def Shader "Preview"
        {
            uniform token info:id = "UsdPreviewSurface"
            color3f inputs:diffuseColor.timeSamples = {
                1: (0.1, 0.25, 1),
                24: (1, 0.32, 0.05),
                48: (0.1, 0.25, 1),
            }
            float inputs:roughness = 0.35
            token outputs:surface
        }
    }
}
