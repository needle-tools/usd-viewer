#usda 1.0

over "World"
{
    def Scope "Looks"
    {
        def Material "NestedTextured"
        {
            token outputs:surface.connect = </World/Looks/NestedTextured/Preview.outputs:surface>

            def Shader "Preview"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor.connect = </World/Looks/NestedTextured/Diffuse.outputs:rgb>
                float inputs:roughness = 0.42
                token outputs:surface
            }

            def Shader "Diffuse"
            {
                uniform token info:id = "UsdUVTexture"
                asset inputs:file = @../textures/nested_checker.png@
                token inputs:sourceColorSpace = "sRGB"
                float2 inputs:st.connect = </World/Looks/NestedTextured/Transform.outputs:result>
                token inputs:wrapS = "repeat"
                token inputs:wrapT = "repeat"
                float3 outputs:rgb
            }

            def Shader "Transform"
            {
                uniform token info:id = "UsdTransform2d"
                float2 inputs:in.connect = </World/Looks/NestedTextured/Primvar.outputs:result>
                float2 inputs:scale = (1.5, 1.5)
                float2 inputs:translation = (0.1, 0.2)
                float2 outputs:result
            }

            def Shader "Primvar"
            {
                uniform token info:id = "UsdPrimvarReader_float2"
                string inputs:varname = "st"
                float2 outputs:result
            }
        }
    }
}
